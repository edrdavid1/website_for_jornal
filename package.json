{
  "name": "journal-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-index.js && vite",
    "build": "node scripts/generate-index.js && node scripts/generate-sitemap.js && tsc -b && vite build",
    "prerender": "node scripts/prerender.cjs",
    "build:prerender": "npm run build && npm run prerender",
    "lint": "eslint .",
    "preview": "npm run build && wrangler dev",
    "generate-index": "node scripts/generate-index.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "test": "vitest run",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "github-slugger": "^2.0.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@eslint/js": "^9.39.1",
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^28.1.0",
    "puppeteer": "^24.40.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  }
